 936:quantum/rgblight.c ****     anim->current_hue++;
 937:quantum/rgblight.c ****   } else {
 938:quantum/rgblight.c ****     anim->current_hue--;
 939:quantum/rgblight.c ****   }
 940:quantum/rgblight.c **** }
